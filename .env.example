# Current execution environment (development, testing, staging, production)
ENV=development

# Enable or disable verbose debug output/logs
DEBUG=true

# Database connection DSN (PostgreSQL)
# Format: postgresql://[user]:[password]@[host]:[port]/[dbname]
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/isb_dev

# Cache connection DSN (Redis)
# Format: redis://[host]:[port]/[db]
REDIS_URL=redis://localhost:6379/0
